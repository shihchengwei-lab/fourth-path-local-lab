{"id":"v9-repair-code-001","category":"v9_capability_repair_code","prompt":"Fix this Python function and return only the corrected function:\n\ndef clamp_percentile(score):\n    return score","target_response":"def clamp_percentile(score):\n    if score < 0:\n        return 0\n    if score > 100:\n        return 100\n    return score","verifier":{"required_regex":["def\\s+clamp_percentile","if\\s+score\\s*<\\s*0","if\\s+score\\s*>\\s*100","return\\s+score"],"python_tests":{"function":"clamp_percentile","cases":[{"args":[-2],"expected":0},{"args":[66],"expected":66},{"args":[120],"expected":100}]},"max_chars":260},"source":"codex_v8_failure_analysis","split":"train_seed","evidence_level":"train_seed_not_capability_evidence","clean_claim_eligible":false,"verifier_labels":["verifier:required_regex","verifier:python_tests","verifier:max_chars"]}
{"id":"v9-repair-code-002","category":"v9_capability_repair_code","prompt":"Fix this Python function and return only the corrected function:\n\ndef value_after_arrow(line):\n    return line.split('->')[0]","target_response":"def value_after_arrow(line):\n    return line.split('->', 1)[1].strip()","verifier":{"required_regex":["def\\s+value_after_arrow","split\\s*\\(\\s*['\"]->['\"]\\s*,\\s*1\\s*\\)\\s*\\[\\s*1\\s*\\]","strip\\s*\\("],"forbidden_regex":["split\\s*\\(\\s*['\"]->['\"]\\s*\\)\\s*\\[\\s*0\\s*\\]"],"python_tests":{"function":"value_after_arrow","cases":[{"args":["owner -> audit"],"expected":"audit"},{"args":["state->ready"],"expected":"ready"}]},"max_chars":240},"source":"codex_v8_failure_analysis","split":"train_seed","evidence_level":"train_seed_not_capability_evidence","clean_claim_eligible":false,"verifier_labels":["verifier:required_regex","verifier:forbidden_regex","verifier:python_tests","verifier:max_chars"]}
{"id":"v9-repair-code-003","category":"v9_capability_repair_code","prompt":"Fix this Python function and return only the corrected function:\n\ndef second_word(text):\n    return text.split()[0]","target_response":"def second_word(text):\n    parts = text.split()\n    return parts[1] if len(parts) >= 2 else None","verifier":{"required_regex":["def\\s+second_word","parts\\s*=\\s*text\\.split\\s*\\(","parts\\[\\s*1\\s*\\]","len\\s*\\(\\s*parts\\s*\\)\\s*>=\\s*2"],"forbidden_regex":["return\\s+text\\.split\\s*\\(\\s*\\)\\s*\\[\\s*0\\s*\\]"],"python_tests":{"function":"second_word","cases":[{"args":["alpha beta gamma"],"expected":"beta"},{"args":["solo"],"expected":null}]},"max_chars":260},"source":"codex_v8_failure_analysis","split":"train_seed","evidence_level":"train_seed_not_capability_evidence","clean_claim_eligible":false,"verifier_labels":["verifier:required_regex","verifier:forbidden_regex","verifier:python_tests","verifier:max_chars"]}
{"id":"v9-repair-code-004","category":"v9_capability_repair_code","prompt":"Fix this Python function and return only the corrected function. Blank text should return 0:\n\ndef count_or_zero(text):\n    return int(text)","target_response":"def count_or_zero(text):\n    return int(text.strip()) if text.strip() else 0","verifier":{"required_regex":["def\\s+count_or_zero","int\\s*\\(\\s*text\\.strip\\s*\\(\\s*\\)\\s*\\)","if\\s+text\\.strip\\s*\\("],"python_tests":{"function":"count_or_zero","cases":[{"args":[" 12 "],"expected":12},{"args":[" "],"expected":0}]},"max_chars":220},"source":"codex_v8_failure_analysis","split":"train_seed","evidence_level":"train_seed_not_capability_evidence","clean_claim_eligible":false,"verifier_labels":["verifier:required_regex","verifier:python_tests","verifier:max_chars"]}
{"id":"v9-repair-code-005","category":"v9_capability_repair_code","prompt":"Fix this Python function and return only the corrected function:\n\ndef trimmed_record(name, role):\n    return {\"name\": name, \"role\": role}","target_response":"def trimmed_record(name, role):\n    return {\"name\": name.strip(), \"role\": role.strip()}","verifier":{"required_regex":["def\\s+trimmed_record","name\\.strip\\s*\\(\\s*\\)","role\\.strip\\s*\\(\\s*\\)"],"forbidden_regex":["return\\s+\\{\\s*[\"']name[\"']:\\s*name\\s*,\\s*[\"']role[\"']:\\s*role\\s*\\}"],"python_tests":{"function":"trimmed_record","cases":[{"args":[" Ada "," audit "],"expected":{"name":"Ada","role":"audit"}}]},"max_chars":220},"source":"codex_v8_failure_analysis","split":"train_seed","evidence_level":"train_seed_not_capability_evidence","clean_claim_eligible":false,"verifier_labels":["verifier:required_regex","verifier:forbidden_regex","verifier:python_tests","verifier:max_chars"]}
