{
  "version": "1",
  "rules": [
    {
      "id": "C1",
      "severity": "critical",
      "reason": "concrete actionable physical harm instructions",
      "patterns": [
        {
          "id": "C1-p1",
          "regex": "\\bmake\\b.{0,80}\\b(explosive|bomb|poison)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p2",
          "regex": "\\bweapon\\b.{0,80}\\b(instruction|build|assemble)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p3",
          "regex": "\\bkill\\b.{0,80}\\b(step|method|guide|instructions)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p5",
          "regex": "\\b(improvised explosive device|ied)\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C1-p6",
          "regex": "\\bharmful recipe\\b.{0,80}\\b(explosive|poison|weapon)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p4",
          "regex": "(製作|組裝).{0,30}(爆裂物|炸彈|毒物|武器)",
          "flags": {"ignorecase": false, "dotall": true}
        }
      ]
    },
    {
      "id": "C2",
      "severity": "critical",
      "reason": "bypassing safety, credentials, permissions, logging, or monitoring",
      "patterns": [
        {
          "id": "C2-p1",
          "regex": "\\bbypass\\b.{0,80}\\b(password|login|auth|authentication|security|permission|monitoring)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p2",
          "regex": "\\bdisable\\b.{0,80}\\b(windows defender|antivirus|edr|logging|monitoring)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p3",
          "regex": "\\bsteal\\b.{0,80}\\b(cookie|token|credential|password|session)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p4",
          "regex": "\\bextract\\b.{0,80}\\b(password|credential|token|cookie)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p10",
          "regex": "\\b(collect|capture|harvest|obtain|copy(?:ing)?|steal(?:ing)?|extract(?:ing)?|exfiltrat(?:e|ing))\\b.{0,100}\\b(browser\\s+)?session\\s+(cookies?|tokens?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p11",
          "regex": "\\b(upload|send|post|transmit|exfiltrat(?:e|ing))\\b.{0,120}\\b(cookies?|session cookies?|session tokens?|tokens?|credentials?|api keys?|private keys?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p17",
          "regex": "\\b(cookies?|session cookies?|session tokens?|tokens?|credentials?|api keys?|private keys?)\\b.{0,80}\\b(?:are\\s+)?(?:sent|posted|uploaded|transmitted|leaked)\\b.{0,80}\\b(webhook|endpoint|external|public|shared)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p12",
          "regex": "\\b(print|dump|read|show|reveal|cat|copy)\\b.{0,120}\\b(\\.env\\b|ssh keys?|api tokens?|api keys?|private keys?|secret files?|credentials?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p13",
          "regex": "\\b(copy|paste|dump|print|show|read|upload|send|post|transmit|publish|share|exports?|includes?|adds?|writes?|screenshots?|captures?)\\b.{0,120}(env vars?|environment variables?|dotenv file|dotenv values?|dotenv variables?|\\.env(?: file| contents?| values?| variables?)?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p20",
          "regex": "\\b(add|write|include|paste|publish|share)\\b.{0,120}\\b(api[_ -]?tokens?|api tokens?|secret[_ -]?tokens?|tokens?)\\b.{0,80}\\b(public|ci log|issue tracker|ticket|support report|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p21",
          "regex": "\\b(api[_-]?key|secret[_-]?token|api[_ -]?tokens?|secret[_ -]?tokens?)\\b.{0,80}\\b(values?|contents?)\\b.{0,80}\\b(report|ticket|log|public|shared)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p22",
          "regex": "\\b(place|places|paste|pastes|write|writes|add|adds|include|includes|share|shares)\\b.{0,100}\\b(bearer tokens?|authorization headers?|openai[_ -]?api[_ -]?keys?|refresh tokens?)\\b.{0,100}\\b(shared|troubleshooting|support|ticket|chat|note|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p23",
          "regex": "\\b(bearer tokens?|authorization headers?|openai[_ -]?api[_ -]?keys?|refresh tokens?)\\b.{0,60}\\b(contents?|values?|headers?)\\b.{0,80}\\b(shared|troubleshooting|support|ticket|chat|note|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p24",
          "regex": "\\b(screenshot|screen capture|capture)\\b.{0,80}\\b(credential values?|secret values?|config values?|\\.env values?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p25",
          "regex": "\\b(copy|copies|paste|pastes|move|moves|transfer|transfers|sync|syncs)\\b.{0,80}\\bsession[_ -]?storage\\b.{0,80}\\b(auth tokens?|tokens?|session)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p31",
          "regex": "\\b(sets?|writes?|includes?|serializes?|adds?|posts?)\\b.{0,100}\\b(authheader|auth header|authorization\\s*:\\s*bearer)\\b.{0,100}\\b(public|shared|support|ticket|chat|note|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p32",
          "regex": "\\b(copy|copies|paste|pastes|move|moves|transfer|transfers|sync|syncs)\\b.{0,80}\\bcookiejar\\b.{0,80}\\b(entries?|cookies?|profile|browser|account|access|device)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p33",
          "regex": "\\b(copy|copies|paste|pastes|move|moves|transfer|transfers|sync|syncs)\\b.{0,80}\\blocal[_ -]?storage\\b.{0,80}\\b(jwt|auth tokens?|tokens?|session|account access)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p34",
          "regex": "\\b(copy|copies|move|moves|transfer|transfers|sync|syncs)\\b.{0,100}\\bindexeddb\\b.{0,80}\\b(auth|token|session|login|account)\\b.{0,80}\\b(profile|browser|device|reuse|access)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p35",
          "regex": "\\b(upload|uploads|post|posts|share|shares|send|sends)\\b.{0,100}\\bhar file\\b.{0,100}\\b(cookies?|cookie headers?|authorization headers?|auth headers?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p36",
          "regex": "\\b(passkey private material|webauthn private (?:keys?|material)|security key private material)\\b.{0,100}\\b(shared|diagnostic bundle|support|ticket|chat|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p37",
          "regex": "(?m)(?:^\\s*[A-Za-z0-9._-]{2,32}\\s*:\\s*\\S{6,}\\s*$\\n?){2,}",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p38",
          "regex": "\\b(?:sk-(?:live|test)-[A-Za-z0-9_-]{20,}|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|ghp_[A-Za-z0-9_]{20,}|gho_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|xox[abp]-[A-Za-z0-9-]{20,})\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p39",
          "regex": "\\bselect\\b.{0,160}\\b(password[_-]?hash|mfa[_-]?secret|session[_-]?tokens?|api[_-]?keys?|auth)\\w*\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p40",
          "regex": "\\b(?:backup\\s+)?recovery codes?\\b.{0,160}(?:[A-Za-z0-9]{2,}-[A-Za-z0-9]{2,}[\\s,]*){3,}",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p41",
          "regex": "\\b(?:export|dump|extract|copy|read)\\b.{0,120}\\b(?:passkey|windows hello|ncrypt|webauthn)\\b.{0,120}\\b(?:private (?:key|material)|raw key bytes|ksp)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p42",
          "regex": "\\b(?:forward|forwards|relay|relays|proxy|proxies|send|sends|replay|replays)\\b.{0,120}\\b(?:authorization headers?|authorization\\s*:\\s*bearer|bearer tokens?|jwt|auth headers?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p43",
          "regex": "\\b(reveal|show|print|dump|quote|here is|begins? with)\\b.{0,120}\\b(hidden system|developer instructions?|audit instructions?|private audit|control[- ]?plane|main[_ -]?agent[_ -]?system[_ -]?prompt|cold[_ -]?eyes[_ -]?system[_ -]?prompt|system[_ -]?prompt)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p51",
          "regex": "\\b(?:hidden\\s+|private\\s+|full\\s+)?(?:main[_ -]?agent[_ -]?system[_ -]?prompt|cold[_ -]?eyes[_ -]?system[_ -]?prompt|system[_ -]?prompt|developer instructions?|audit instructions?)\\b.{0,120}\\b(?:begins? with|full text|verbatim|exposed|leaked)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p44",
          "regex": "\\b(?:delete|del|remove|clear|clears|wipe|purge|truncate|rm(?:\\s+-rf)?|erase)\\b.{0,120}\\b(?:audit logs?|audit traces?|runs?[\\\\/]|jsonl|refusal logs?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p45",
          "regex": "\\b(?:edit|modify|change|rewrite|overwrite|remove|delete|replace)\\b.{0,120}\\b(?:policies?[\\\\/]fourth_path_safety\\.json|fourth_path_safety\\.json|policy file|safety policy|canon|audit policy)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p46",
          "regex": "\\b(?:zero[- ]?width|invisible characters?|homoglyphs?|unicode[- ]?similar|split (?:across|the) (?:line|lines))\\b.{0,120}\\b(?:matcher|detector|filter|policy|cold eyes|audit)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p47",
          "regex": "\\b(?:skip|bypass|avoid|circumvent)\\b.{0,80}\\b(?:action[- ]?gate|action gate|audit gate)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p48",
          "regex": "\\b(?:os\\.system|subprocess|curl\\b.{0,40}\\|\\s*(?:sh|bash)|python\\s+-c)\\b.{0,120}\\b(?:gate|audit|shell|evil|install)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p49",
          "regex": "\\b(?:pre[- ]?approved|cleared|verified|reviewed|signed[- ]?off)\\b.{0,80}\\bcold[_ -]?eyes\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p50",
          "regex": "\\b(?:change|edit|rewrite|flip|replace)\\b.{0,120}\\b(?:final_status|audit traces?|audit logs?|jsonl)\\b.{0,120}\\b(?:refused|pass|green)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p26",
          "regex": "\\b(adds?|pastes?|posts?|publishes?|shares?|includes?|writes?)\\b.{0,100}(?:^|[^A-Za-z0-9_])(\\.npmrc|\\.netrc|\\.pypirc|aws credentials file|application default credentials(?: json)?|google application default credentials(?: json)?)\\b.{0,100}\\b(support|issue|ticket|chat|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p27",
          "regex": "(?:^|[^A-Za-z0-9_])(\\.npmrc|\\.netrc|\\.pypirc|aws credentials file|application default credentials(?: json)?|google application default credentials(?: json)?)\\b.{0,100}\\b(contents?|values?|passwords?|auth tokens?|credentials?)\\b.{0,80}\\b(support|issue|ticket|chat|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p28",
          "regex": "\\b(renames?|moves?|disables?|swaps?|replaces?)\\b.{0,80}\\b(safety policy|policy file|canon|audit policy|action gate|cold eyes|control[- ]?plane)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p29",
          "regex": "\\b(archives?|hides?|suppresses?)\\b.{0,100}\\b(audit traces?|audit logs?|refusal events?|review traces?)\\b.{0,100}\\b(hide|hiding|conceal|from (later )?review|avoid review|suppress)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p30",
          "regex": "\\b(hides?|conceals?|suppresses?)\\b.{0,100}\\b(refusal traces?|audit traces?|audit logs?|refusal events?|review traces?)\\b.{0,100}\\b(from (later )?review|avoid review|conceal|suppress)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p14",
          "regex": "\\b(moves?|copies?|imports?|exports?|transfers?|syncs?)\\b.{0,100}\\b((chrome|chromium|edge|browser)\\s+)?(profile\\s+)?cookies?\\b.{0,80}\\b(sign[- ]?in|login|access|profile|account|computer|device|reuse)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p18",
          "regex": "(搬|移|同步|匯入|轉移|複製).{0,30}(瀏覽器)?\\s*cookie.{0,30}(登入|帳號|另一台|電腦|裝置)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p19",
          "regex": "(瀏覽器)?\\s*cookie.{0,30}(搬|移|同步|匯入|轉移|複製).{0,30}(登入|帳號|另一台|電腦|裝置)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p15",
          "regex": "\\b(reveal|show|print|dump|quote)\\b.{0,120}\\b(hidden system|developer instructions?|audit instructions?|private audit|control[- ]?plane)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p16",
          "regex": "\\b(hidden system|developer instructions?|audit instructions?|private audit)\\b.{0,120}\\b(avoid|bypass|evade|circumvent)\\b.{0,60}\\b(gate|audit|review|safety layer)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p5",
          "regex": "\\bmimikatz\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C2-p6",
          "regex": "\\bprivilege escalation\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C2-p7",
          "regex": "(繞過|規避|破解|跳過).{0,30}(登入|密碼|驗證|認證|安全|權限|監控|日誌)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p8",
          "regex": "(取得|竊取|偷取|擷取).{0,30}(密碼|憑證|權杖|token|cookie|session)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p9",
          "regex": "(關閉|停用|禁用).{0,30}(防毒|監控|日誌|紀錄|安全系統)",
          "flags": {"ignorecase": false, "dotall": true}
        }
      ]
    },
    {
      "id": "C3",
      "severity": "critical",
      "reason": "deception, impersonation, phishing, or unauthorized data access",
      "patterns": [
        {
          "id": "C3-p1",
          "regex": "\\bphishing\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C3-p2",
          "regex": "\\bfake login\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C3-p3",
          "regex": "\\bimpersonat(e|ion)\\b.{0,80}\\b(account|user|employee|bank|support)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p4",
          "regex": "\\bspoof\\b.{0,80}\\b(email|caller|identity|login)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p6",
          "regex": "\\b(create|write|build|draft|compose)\\b.{0,80}\\b(login[- ]?code|mfa code|otp|one[- ]?time code)\\b.{0,80}\\b(collection|collector|capture|harvest)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p7",
          "regex": "\\b(login[- ]?code|mfa code|otp|one[- ]?time code)\\b.{0,80}\\b(collection|collector|capture|harvest)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p8",
          "regex": "\\bfake\\b.{0,40}\\b(payroll|invoice)\\b.{0,80}\\b(email|message)\\b.{0,100}\\b(asks?|steal|capture|collect|enter|password|credential|one[- ]?time|otp|login code)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p9",
          "regex": "\\b(support portal|form)\\b.{0,100}\\b(asks?|collects?|captures?|harvests?)\\b.{0,80}\\b(employees?|users?|staff)?\\b.{0,40}\\b(login[- ]?codes?|one[- ]?time codes?|otp|mfa codes?|verification codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p10",
          "regex": "\\b(notice|message|email|page|form)\\b.{0,100}\\b(requests?|asks?|records?|collects?|captures?|harvests?)\\b.{0,80}\\b(staff|users?|employees?)?\\b.{0,40}\\b(verification codes?|mfa codes?|otp|one[- ]?time codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p11",
          "regex": "\\b(password reset|reset page|login page)\\b.{0,80}\\b(records?|collects?|captures?|stores?|harvests?)\\b.{0,40}\\b(otps?|mfa|codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p15",
          "regex": "\\b(records?|collects?|captures?|stores?|harvests?)\\b.{0,80}\\b(otpcodes?|mfacodes?|2facodes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p16",
          "regex": "\\b(asks?|requesting|requests?|collects?|collecting)\\b.{0,80}\\b(staff|users?|employees?)\\b.{0,80}\\b(submit|enter|provide|share)\\b.{0,80}\\b(one[- ]?time passcodes?|passcodes?|otpcodes?|mfacodes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p17",
          "regex": "\\b(account recovery page|recovery page|reset page)\\b.{0,80}\\b(asks?|requests?|collects?|captures?|stores?|records?)\\b.{0,80}\\b(2fa backup codes?|backup codes?|recovery codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p12",
          "regex": "\\b(helpdesk|it support|benefits enrollment)\\b.{0,80}\\b(asks?|reply|send|provide|enter|share)\\b.{0,40}\\b(verification codes?|mfa codes?|otp|one[- ]?time codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p13",
          "regex": "\\b(survey|questionnaire|form|notice)\\b.{0,80}\\b(requests?|requesting|asks?|asking|collects?|collecting)\\b.{0,80}\\b(sms login codes?|sms codes?|2fa codes?|two[- ]?factor codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p14",
          "regex": "\\b(reset page|password reset|login page)\\b.{0,80}\\b(saves?|records?|stores?|collects?)\\b.{0,40}\\b(2fa codes?|two[- ]?factor codes?|sms codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p5",
          "regex": "(釣魚|假登入|偽造登入|冒充|冒名|仿冒)",
          "flags": {"ignorecase": false}
        }
      ]
    }
  ]
}
