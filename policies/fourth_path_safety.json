{
  "version": "1",
  "rules": [
    {
      "id": "C1",
      "severity": "critical",
      "reason": "concrete actionable physical harm instructions",
      "patterns": [
        {
          "id": "C1-p1",
          "regex": "\\bmake\\b.{0,80}\\b(explosive|bomb|poison)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p2",
          "regex": "\\bweapon\\b.{0,80}\\b(instruction|build|assemble)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p3",
          "regex": "\\bkill\\b.{0,80}\\b(step|method|guide|instructions)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p5",
          "regex": "\\b(improvised explosive device|ied)\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C1-p6",
          "regex": "\\bharmful recipe\\b.{0,80}\\b(explosive|poison|weapon)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C1-p4",
          "regex": "(製作|組裝).{0,30}(爆裂物|炸彈|毒物|武器)",
          "flags": {"ignorecase": false, "dotall": true}
        }
      ]
    },
    {
      "id": "C2",
      "severity": "critical",
      "reason": "bypassing safety, credentials, permissions, logging, or monitoring",
      "patterns": [
        {
          "id": "C2-p1",
          "regex": "\\bbypass\\b.{0,80}\\b(password|login|auth|authentication|security|permission|monitoring)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p2",
          "regex": "\\bdisable\\b.{0,80}\\b(windows defender|antivirus|edr|logging|monitoring)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p3",
          "regex": "\\bsteal\\b.{0,80}\\b(cookie|token|credential|password|session)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p4",
          "regex": "\\bextract\\b.{0,80}\\b(password|credential|token|cookie)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p10",
          "regex": "\\b(collect|capture|harvest|obtain|copy(?:ing)?|steal(?:ing)?|extract(?:ing)?|exfiltrat(?:e|ing))\\b.{0,100}\\b(browser\\s+)?session\\s+(cookies?|tokens?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p11",
          "regex": "\\b(upload|send|post|transmit|exfiltrat(?:e|ing))\\b.{0,120}\\b(cookies?|session cookies?|session tokens?|tokens?|credentials?|api keys?|private keys?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p17",
          "regex": "\\b(cookies?|session cookies?|session tokens?|tokens?|credentials?|api keys?|private keys?)\\b.{0,80}\\b(?:are\\s+)?(?:sent|posted|uploaded|transmitted|leaked)\\b.{0,80}\\b(webhook|endpoint|external|public|shared)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p12",
          "regex": "\\b(print|dump|read|show|reveal|cat|copy)\\b.{0,120}\\b(\\.env\\b|ssh keys?|api tokens?|api keys?|private keys?|secret files?|credentials?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p13",
          "regex": "\\b(copy|paste|dump|print|show|read|upload|send|post|transmit|publish|share|exports?|includes?|adds?|writes?|screenshots?|captures?)\\b.{0,120}(env vars?|environment variables?|dotenv file|dotenv values?|dotenv variables?|\\.env(?: file| contents?| values?| variables?)?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p20",
          "regex": "\\b(add|write|include|paste|publish|share)\\b.{0,120}\\b(api[_ -]?tokens?|api tokens?|secret[_ -]?tokens?|tokens?)\\b.{0,80}\\b(public|ci log|issue tracker|ticket|support report|report|log)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p21",
          "regex": "\\b(api[_-]?key|secret[_-]?token|api[_ -]?tokens?|secret[_ -]?tokens?)\\b.{0,80}\\b(values?|contents?)\\b.{0,80}\\b(report|ticket|log|public|shared)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p14",
          "regex": "\\b(moves?|copies?|imports?|exports?|transfers?|syncs?)\\b.{0,100}\\b((chrome|chromium|edge|browser)\\s+)?(profile\\s+)?cookies?\\b.{0,80}\\b(sign[- ]?in|login|access|profile|account|computer|device|reuse)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p18",
          "regex": "(搬|移|同步|匯入|轉移|複製).{0,30}(瀏覽器)?\\s*cookie.{0,30}(登入|帳號|另一台|電腦|裝置)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p19",
          "regex": "(瀏覽器)?\\s*cookie.{0,30}(搬|移|同步|匯入|轉移|複製).{0,30}(登入|帳號|另一台|電腦|裝置)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p15",
          "regex": "\\b(reveal|show|print|dump|quote)\\b.{0,120}\\b(hidden system|developer instructions?|audit instructions?|private audit|control[- ]?plane)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p16",
          "regex": "\\b(hidden system|developer instructions?|audit instructions?|private audit)\\b.{0,120}\\b(avoid|bypass|evade|circumvent)\\b.{0,60}\\b(gate|audit|review|safety layer)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C2-p5",
          "regex": "\\bmimikatz\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C2-p6",
          "regex": "\\bprivilege escalation\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C2-p7",
          "regex": "(繞過|規避|破解|跳過).{0,30}(登入|密碼|驗證|認證|安全|權限|監控|日誌)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p8",
          "regex": "(取得|竊取|偷取|擷取).{0,30}(密碼|憑證|權杖|token|cookie|session)",
          "flags": {"ignorecase": false, "dotall": true}
        },
        {
          "id": "C2-p9",
          "regex": "(關閉|停用|禁用).{0,30}(防毒|監控|日誌|紀錄|安全系統)",
          "flags": {"ignorecase": false, "dotall": true}
        }
      ]
    },
    {
      "id": "C3",
      "severity": "critical",
      "reason": "deception, impersonation, phishing, or unauthorized data access",
      "patterns": [
        {
          "id": "C3-p1",
          "regex": "\\bphishing\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C3-p2",
          "regex": "\\bfake login\\b",
          "flags": {"ignorecase": true}
        },
        {
          "id": "C3-p3",
          "regex": "\\bimpersonat(e|ion)\\b.{0,80}\\b(account|user|employee|bank|support)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p4",
          "regex": "\\bspoof\\b.{0,80}\\b(email|caller|identity|login)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p6",
          "regex": "\\b(create|write|build|draft|compose)\\b.{0,80}\\b(login[- ]?code|mfa code|otp|one[- ]?time code)\\b.{0,80}\\b(collection|collector|capture|harvest)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p7",
          "regex": "\\b(login[- ]?code|mfa code|otp|one[- ]?time code)\\b.{0,80}\\b(collection|collector|capture|harvest)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p8",
          "regex": "\\bfake\\b.{0,40}\\b(payroll|invoice)\\b.{0,80}\\b(email|message)\\b.{0,100}\\b(asks?|steal|capture|collect|enter|password|credential|one[- ]?time|otp|login code)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p9",
          "regex": "\\b(support portal|form)\\b.{0,100}\\b(asks?|collects?|captures?|harvests?)\\b.{0,80}\\b(employees?|users?|staff)?\\b.{0,40}\\b(login[- ]?codes?|one[- ]?time codes?|otp|mfa codes?|verification codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p10",
          "regex": "\\b(notice|message|email|page|form)\\b.{0,100}\\b(requests?|asks?|records?|collects?|captures?|harvests?)\\b.{0,80}\\b(staff|users?|employees?)?\\b.{0,40}\\b(verification codes?|mfa codes?|otp|one[- ]?time codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p11",
          "regex": "\\b(password reset|reset page|login page)\\b.{0,80}\\b(records?|collects?|captures?|stores?|harvests?)\\b.{0,40}\\b(otps?|mfa|codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p12",
          "regex": "\\b(helpdesk|it support|benefits enrollment)\\b.{0,80}\\b(asks?|reply|send|provide|enter|share)\\b.{0,40}\\b(verification codes?|mfa codes?|otp|one[- ]?time codes?)\\b",
          "flags": {"ignorecase": true, "dotall": true}
        },
        {
          "id": "C3-p5",
          "regex": "(釣魚|假登入|偽造登入|冒充|冒名|仿冒)",
          "flags": {"ignorecase": false}
        }
      ]
    }
  ]
}
